<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/sep_date_holder"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="5dp"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="horizontal">
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/date_sep"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:rippleColor="#20607D8B"
			app:strokeWidth="0dp"
			app:strokeColor="#60607D8B"
			app:cardCornerRadius="55dp"
			app:cardElevation="0dp"
			app:cardBackgroundColor="@color/sep_lay">
			<LinearLayout
				android:id="@+id/linear12"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:paddingLeft="15dp"
				android:paddingTop="3dp"
				android:paddingRight="15dp"
				android:paddingBottom="3dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/date_sep_txt"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="June 26"
					android:textSize="14sp"
					android:textColor="@color/button_bg_light" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/sender"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="right|center_vertical"
		android:orientation="horizontal">
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/sender_cd"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginLeft="45dp"
			app:rippleColor="#20607D8B"
			app:strokeWidth="0dp"
			app:strokeColor="#60607D8B"
			app:cardCornerRadius="0dp"
			app:cardElevation="0dp"
			app:cardBackgroundColor="@color/sender_bg">
			<LinearLayout
				android:id="@+id/sender_bg"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="2dp"
				android:paddingTop="2dp"
				android:paddingRight="2dp"
				android:paddingBottom="1dp"
				android:gravity="center_vertical"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/sender_reply_holder"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="6dp"
					android:layout_marginTop="5dp"
					android:layout_marginRight="6dp"
					android:layout_marginBottom="5dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/sender_reply_cd"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						app:rippleColor="#20607D8B"
						app:strokeWidth="0dp"
						app:strokeColor="#60607D8B"
						app:cardCornerRadius="10dp"
						app:cardElevation="0dp"
						app:cardBackgroundColor="@color/sender_reply_cd">
						<LinearLayout
							android:id="@+id/linear4"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/sender_reply_sep"
								android:layout_width="3dp"
								android:layout_height="match_parent"
								android:padding="8dp"
								android:background="@color/sender_reply_header_txt"
								android:orientation="vertical" />
							<LinearLayout
								android:id="@+id/linear3"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="8dp"
								android:paddingTop="3dp"
								android:paddingRight="8dp"
								android:paddingBottom="3dp"
								android:gravity="center_vertical"
								android:orientation="vertical">
								<TextView
									android:id="@+id/sender_reply_header"
									android:focusable="false"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="CoderDevs"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="@color/sender_reply_header_txt" />
								<TextView
									android:id="@+id/sender_reply_sub"
									android:focusable="false"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="Hey man how are you doing"
									android:textSize="14sp"
									android:textColor="@color/text_header" />
							</LinearLayout>
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/ImagesHolder_cd"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="1dp"
					android:layout_marginBottom="5dp"
					app:cardBackgroundColor="@android:color/transparent"
					app:rippleColor="#20607D8B"
					app:strokeWidth="0dp"
					app:strokeColor="#60607D8B"
					app:cardCornerRadius="10dp"
					app:cardElevation="0dp">
					<LinearLayout
						android:id="@+id/image_card_inner"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="2dp"
						android:orientation="horizontal">
						<com.google.android.material.card.MaterialCardView
							android:id="@+id/sc1_cd"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginRight="2dp"
							app:cardBackgroundColor="@android:color/transparent"
							android:layout_weight="1"
							app:rippleColor="#20607D8B"
							app:strokeWidth="0dp"
							app:strokeColor="#60607D8B"
							app:cardCornerRadius="5dp"
							app:cardElevation="0dp">
							<LinearLayout
								android:id="@+id/sec1"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical">
								<ImageView
									android:id="@+id/sc1_img"
									android:focusable="false"
									android:layout_width="match_parent"
									android:layout_height="300dp"
									android:src="@drawable/testsc"
									android:scaleType="centerCrop" />
							</LinearLayout>
						</com.google.android.material.card.MaterialCardView>
						<LinearLayout
							android:id="@+id/linear14"
							android:layout_width="wrap_content"
							android:layout_height="match_parent"
							android:padding="2dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="vertical"
							android:layout_weight="1">
							<com.google.android.material.card.MaterialCardView
								android:id="@+id/sc2_cd"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginBottom="2dp"
								app:cardBackgroundColor="@android:color/transparent"
								android:layout_weight="1"
								app:rippleColor="#20607D8B"
								app:strokeWidth="0dp"
								app:strokeColor="#60607D8B"
								app:cardCornerRadius="5dp"
								app:cardElevation="0dp">
								<LinearLayout
									android:id="@+id/linear15"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:gravity="center_vertical"
									android:orientation="vertical">
									<ImageView
										android:id="@+id/sc2_img"
										android:focusable="false"
										android:layout_width="wrap_content"
										android:layout_height="wrap_content"
										android:src="@drawable/bg_black"
										android:scaleType="centerCrop" />
								</LinearLayout>
							</com.google.android.material.card.MaterialCardView>
							<com.google.android.material.card.MaterialCardView
								android:id="@+id/sc3_cd"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								app:cardBackgroundColor="@android:color/transparent"
								android:layout_weight="1"
								app:rippleColor="#20607D8B"
								app:strokeWidth="0dp"
								app:strokeColor="#60607D8B"
								app:cardCornerRadius="5dp"
								app:cardElevation="0dp">
								<LinearLayout
									android:id="@+id/linear16"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:gravity="center_vertical"
									android:orientation="vertical">
									<ImageView
										android:id="@+id/sc3_img"
										android:focusable="false"
										android:layout_width="wrap_content"
										android:layout_height="match_parent"
										android:src="@drawable/bg_light_normal"
										android:scaleType="centerCrop" />
								</LinearLayout>
							</com.google.android.material.card.MaterialCardView>
						</LinearLayout>
					</LinearLayout>
				</com.google.android.material.card.MaterialCardView>
				<TextView
					android:id="@+id/sender_txt"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="3dp"
					android:paddingLeft="8dp"
					android:paddingTop="8dp"
					android:text="Hey man, what's up\?"
					android:textSize="16sp"
					android:textColor="@color/text_header" />
				<LinearLayout
					android:id="@+id/linear13"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:gravity="right|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="right">
					<TextView
						android:id="@+id/sender_time"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginRight="5dp"
						android:text="11:34 PM"
						android:textSize="12sp"
						android:textColor="@color/text_header" />
					<ImageView
						android:id="@+id/imageview1"
						android:focusable="false"
						android:layout_width="15dp"
						android:layout_height="15dp"
						android:src="@drawable/msg_mini_checks"
						android:scaleType="center" />
				</LinearLayout>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/receiver"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="left|center_vertical"
		android:orientation="horizontal">
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/receiver_cd"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginRight="45dp"
			app:rippleColor="#20607D8B"
			app:strokeWidth="0dp"
			app:strokeColor="#60607D8B"
			app:cardCornerRadius="0dp"
			app:cardElevation="0dp"
			app:cardBackgroundColor="@color/receiver_bg">
			<LinearLayout
				android:id="@+id/receiver_bg"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingTop="8dp"
				android:paddingRight="8dp"
				android:paddingBottom="6dp"
				android:gravity="center_vertical"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/receiver_reply_holder"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/receiver_reply_cd"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						app:rippleColor="#20607D8B"
						app:strokeWidth="0dp"
						app:strokeColor="#60607D8B"
						app:cardCornerRadius="10dp"
						app:cardElevation="0dp"
						app:cardBackgroundColor="@color/receiver_reply_cd">
						<LinearLayout
							android:id="@+id/linear9"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/receiver_reply_sep"
								android:layout_width="3dp"
								android:layout_height="match_parent"
								android:padding="8dp"
								android:background="@color/alternate_color"
								android:orientation="vertical" />
							<LinearLayout
								android:id="@+id/linear11"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingLeft="8dp"
								android:paddingTop="5dp"
								android:paddingRight="8dp"
								android:paddingBottom="5dp"
								android:gravity="center_vertical"
								android:orientation="vertical">
								<TextView
									android:id="@+id/receiver_reply_header"
									android:focusable="false"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="CoderDevs"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="@color/alternate_color" />
								<TextView
									android:id="@+id/receiver_reply_sub"
									android:focusable="false"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="Hey man how are you doing"
									android:textSize="14sp"
									android:textColor="@color/text_header" />
							</LinearLayout>
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
				<TextView
					android:id="@+id/receiver_txt"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="3dp"
					android:text="Am good and you\?"
					android:textSize="16sp"
					android:textColor="@color/text_header" />
				<TextView
					android:id="@+id/receiver_time"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="11:34 PM"
					android:textSize="12sp"
					android:textColor="@color/text_header" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/typing_holder"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="center_vertical"
		android:orientation="horizontal">
		<com.airbnb.lottie.LottieAnimationView
			android:id="@+id/lottie1"
			android:layout_width="35dp"
			android:layout_height="35dp"
			android:layout_marginLeft="3dp"
			android:scaleType="fitCenter"
			android:layout_centerInParent="true"
			app:lottie_fileName="bubble.json"
			app:lottie_loop="true"
			app:lottie_autoPlay="true" />
	</LinearLayout>
</LinearLayout>
